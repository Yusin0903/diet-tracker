# --- 資料庫 ---------------------------------------------------------------
# Zeabur 開好 Postgres 後,在後端 service 引用 ${postgres.DATABASE_URL}
DATABASE_URL=postgresql://user:password@localhost:5432/diet

# --- Gemini(只放後端,絕不進前端) --------------------------------------
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# --- 邀請碼(逗號分隔,沒有有效邀請碼就不能註冊) -----------------------
INVITE_CODES=alpha2026,bravo2026

# --- 認證 -----------------------------------------------------------------
# 正式環境務必換成一組長亂數(例如 openssl rand -hex 32)
SECRET_KEY=change-me-to-a-long-random-string
TOKEN_TTL_DAYS=30

# --- 每日目標(可選,不設就用 config.py 預設) --------------------------
# CALORIES_MIN=1700
# CALORIES_MAX=1900
# PROTEIN_MIN=150

# --- 時區 -----------------------------------------------------------------
TZ=Asia/Taipei
