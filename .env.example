# --- 資料庫 ---------------------------------------------------------------
# Zeabur 開好 Postgres 後,在後端 service 引用 ${postgres.DATABASE_URL}
DATABASE_URL=postgresql://user:password@localhost:5432/diet

# --- Gemini(只放後端,絕不進前端) --------------------------------------
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# --- 邀請碼(逗號分隔,沒有有效邀請碼就不能註冊) -----------------------
# 用「高熵」隨機碼,別用好記單字+年份(會被暴力試出來)。
# 產生:openssl rand -hex 16
INVITE_CODES=3f9a1c8e7b2d4f60a1c8e7b2d4f60abc,7b2d4f60a1c8e7b2d4f603f9a1c8e7b2

# --- 速率限制(擋暴力嘗試,可選,不設就用預設) ------------------------
# REG_MAX_FAILURES=8      # 同 IP 註冊失敗幾次就鎖
# REG_WINDOW_S=600        # 計數視窗(秒)
# REG_BLOCK_S=1800        # 鎖定時間(秒)
# LOGIN_MAX_FAILURES=10
# LOGIN_WINDOW_S=600
# LOGIN_BLOCK_S=900

# 反向代理層數:取真實來源 IP 時,從 X-Forwarded-For 右邊數第幾個。
# Zeabur 等單層反代填 1(預設)。填對才能防止偽造 XFF 繞過限流。
# TRUSTED_PROXY_HOPS=1

# /api/analyze(會呼叫 Gemini,要花錢)的濫用限制
# MAX_UPLOAD_MB=8             # 上傳圖片大小上限(MB)
# ANALYZE_MAX_PER_WINDOW=20   # 每位會員在視窗內可呼叫幾次
# ANALYZE_WINDOW_S=600        # 視窗長度(秒)

# --- 認證 -----------------------------------------------------------------
# 正式環境務必換成一組長亂數(例如 openssl rand -hex 32)
SECRET_KEY=change-me-to-a-long-random-string
TOKEN_TTL_DAYS=30

# 註:每日目標已改為每位會員自行設定(填規格估 TDEE 或手動),不再用環境變數。

# --- 時區 -----------------------------------------------------------------
TZ=Asia/Taipei
